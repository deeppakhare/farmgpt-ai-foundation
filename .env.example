# ─────────────────────────────────────────────────────────────
# FarmGPT AI — Environment Variables
# Copy this file to `.env` and fill in the values.
# Never commit `.env` to version control.
# ─────────────────────────────────────────────────────────────

# ── Supabase (client-side, safe to expose) ───────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
VITE_SUPABASE_PROJECT_ID=your-project-ref

# ── Supabase (server-side, used by SSR + server functions) ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# ── Supabase Service Role (SERVER-ONLY, NEVER in client) ─────
# Used only inside *.server.ts modules for admin operations
# such as auth.admin.deleteUser. Guard behind auth + role check.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Lovable AI Gateway (Gemini access) ───────────────────────
# Auto-provisioned when you enable Lovable Cloud.
LOVABLE_API_KEY=lov_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional integrations ────────────────────────────────────
# Uncomment and fill in when the corresponding feature is enabled.

# Live weather provider (e.g. OpenWeather, WeatherAPI)
# WEATHER_API_KEY=

# data.gov.in mandi price feed
# MANDI_API_KEY=

# GitHub connector (only if the app calls the GitHub API at runtime)
# GITHUB_API_KEY=
